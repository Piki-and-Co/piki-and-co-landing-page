---
import '@/styles/biumiz.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Biumiz — L'application qui accompagne votre enfant.",
  image,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image
  ? new URL(image, Astro.site).href
  : new URL('/assets/logo.png', Astro.site).href;

const appSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Biumiz",
  "applicationCategory": "EducationalApplication",
  "operatingSystem": "Web, iOS, Android",
  "description": "Application éducative qui accompagne les enfants de 4 à 10 ans dans le développement des compétences psychosociales via des jeux vidéo immersifs et engageants.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" },
  "author": {
    "@type": "Organization",
    "name": "Piki & Co",
    "url": "https://piki-and-co.com",
  },
  "url": "https://piki-and-co.com/biumiz",
});
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Piki & Co" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <title>{title} | Biumiz</title>
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/x-icon" href="/assets/logo.ico" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={`${title} | Biumiz`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="Biumiz by Piki & Co" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | Biumiz`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={appSchema} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <slot name="head" />
  <!-- TarteAuCitron — consentement cookies -->
  <script src="https://cdn.jsdelivr.net/npm/tarteaucitronjs@latest/tarteaucitron.js" is:inline></script>
  <script src="/js/tarteaucitron-init.js" is:inline></script>
</head>
<body>
  <header>
    <nav class="nav">
      <a href="/">
        <img src="/assets/logo.png" alt="Piki & Co" width="48" height="48" loading="eager" />
      </a>
      <ul class="nav-links">
        <li><a href="/biumiz#fonctionnalites">Fonctionnalités</a></li>
        <li><a href="/biumiz#faq">FAQ</a></li>
        <li><a href="/">Piki & Co</a></li>
        <li><a href="/inscription" class="btn-primary">Rejoindre l'aventure !</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <p>&copy; {new Date().getFullYear()} Piki & Co — Tous droits réservés</p>
    <nav class="footer-socials" aria-label="Réseaux sociaux">
      <a href="https://www.tiktok.com/@piki.and.co" target="_blank" rel="noopener noreferrer">TikTok</a>
      <a href="https://www.instagram.com/piki.and.co/" target="_blank" rel="noopener noreferrer">Instagram</a>
      <a href="https://www.facebook.com/61588273838732" target="_blank" rel="noopener noreferrer">Facebook</a>
    </nav>
    <p><a href="/legal/mention">Mentions légales</a> · <a href="/legal/privacy">Politique de confidentialité</a> · <a href="/legal/cookies">Cookies</a></p>
  </footer>
</body>
</html>
