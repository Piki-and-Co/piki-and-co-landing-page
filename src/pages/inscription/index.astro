---
import BiumizLayout from '@/layouts/BiumizLayout.astro';
---

<BiumizLayout
  title="Inscription"
  description="Rejoignez la communauté Piki & Co et suivez les aventures de Biumiz !"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://sibforms.com/forms/end-form/build/sib-styles.css" />
    <style>
      /* Surcharge styles Brevo pour intégration */
      input.input { width: unset; }
	  input.input-text { 
		  width: 100%; 
		  padding: 0.4rem;
	  }
      .entry__error--primary {
        font-size: 16px;
        text-align: left;
        font-family: Helvetica, sans-serif;
        color: #661d1d;
        background-color: #CC616A;
        border-radius: 3px;
        border-color: #ff4949;
      }
      #sib-container {
        max-width: 36rem;
        margin: 0 auto;
        background: rgba(255,255,255,0.08);
        border-radius: 1rem;
        padding: 2rem;
      }
      #form-title p {
        font-family: var(--font-display);
        font-size: 2rem;
        color: var(--white);
        text-align: center;
        margin-bottom: 1rem;
      }
      .explicative-text p {
        color: rgba(255,255,255,0.8);
        text-align: center;
        margin-bottom: 1.5rem;
        line-height: 1.6;
      }
      .sib-form-block label { color: var(--white); }
      #sib-form button[type="submit"] {
        background: var(--dark-yellow);
        color: #1E1040;
        font-family: var(--font-display);
        font-size: 1.4rem;
        font-weight: 600;
        padding: 0.75rem 2rem;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        width: 100%;
        margin-top: 0.5rem;
        transition: background 0.2s;
      }
      #sib-form button[type="submit"]:hover { background: var(--light-yellow); }
    </style>
  </Fragment>

  <section class="section--tinted" style="padding: 4rem 5%; min-height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center;">
    <div id="sib-form-container" class="container" style="width: 100%; max-width: 40rem;">

      <div id="error-message" class="sib-form-message-panel" style="display:none;">
        <div class="sib-form-message-panel__text sib-form-message-panel__text--center">
          <span class="sib-form-message-panel__inner-text">
            Hmmm, il semble qu'il y ait eu un problème. Nous n'avons pas pu confirmer votre inscription.
          </span>
        </div>
      </div>

      <div id="success-message" class="sib-form-message-panel" style="display:none;">
        <div class="sib-form-message-panel__text sib-form-message-panel__text--center">
          <span class="sib-form-message-panel__inner-text">Merci d'avoir rejoint notre communauté !</span>
        </div>
      </div>

      <div id="sib-container" class="container">
        <form
          id="sib-form"
          method="POST"
          action="https://d83ccb86.sibforms.com/serve/MUIFADWLy0XP-ZwVPt5A5pZp1tFIBd9OLwPZOIp5yentOzqqIfrBF15IZ-_2ASOqPfnWIo8c2Ze6UHX0vbTWye4BIs7myQm04DMCyTpo8WUVU-jiFz7vL3ppmjOis0Egl3IHc6AXQgDzwXrcZdUaXB_9cqwSYJQIkMdcPhMe9cE41T4d8pGw8B-d7xuAVFzyBSa6cQCkYgoyr5YxnA=="
          data-type="subscription"
        >
          <div id="form-title"><p>Rejoignez la communauté !</p></div>

          <div class="explicative-text">
            <p>
              Inscrivez-vous pour ne rien rater de l'actualité de Piki &amp; Co !
              Nous vous informerons des étapes franchies, des campagnes de tests,
              du lancement des préventes et du jeu Biumiz.
            </p>
          </div>

          <div style="padding: 8px 0">
            <div class="sib-input sib-form-block">
              <div class="form__entry entry_block">
                <div class="form__label-row">
                  <label for="NOM" data-required="*">Votre NOM</label>
                  <div class="entry-field">
                    <input class="input-text input" maxlength="200" type="text" id="NOM" name="NOM"
                      placeholder="Votre nom de famille" data-required="true" autocomplete="family-name" required />
                  </div>
                </div>
                <label class="entry__error entry__error--primary"></label>
              </div>
            </div>
          </div>

          <div style="padding: 8px 0">
            <div class="sib-input sib-form-block">
              <div class="form__entry entry_block">
                <div class="form__label-row">
                  <label for="PRENOM" data-required="*">Votre PRÉNOM</label>
                  <div class="entry-field">
                    <input class="input-text input" maxlength="200" type="text" id="PRENOM" name="PRENOM"
                      placeholder="Votre prénom" data-required="true" autocomplete="given-name" required />
                  </div>
                </div>
                <label class="entry__error entry__error--primary"></label>
              </div>
            </div>
          </div>

          <div style="padding: 8px 0">
            <div class="sib-input sib-form-block">
              <div class="form__entry entry_block">
                <div class="form__label-row">
                  <label for="EMAIL" data-required="*">Votre EMAIL</label>
                  <div class="entry-field">
                    <input class="input-text input" type="email" id="EMAIL" name="EMAIL"
                      placeholder="exemple@fournisseur.com" data-required="true" autocomplete="email" required />
                  </div>
                </div>
                <label class="entry__error entry__error--primary"></label>
              </div>
            </div>
          </div>

          <div style="padding: 8px 0">
            <div class="g-recaptcha-v3" data-sitekey="6LfDOhQsAAAAAP1op3mXkpeQaln-uQ0ucAESOmXG" style="display: none"></div>
          </div>

          <div style="padding: 8px 0">
            <div class="sib-optin sib-form-block" data-required="true">
              <div class="form__entry entry_mcq">
                <div class="form__label-row">
                  <div class="entry__choice">
                    <label for="OPT_IN">
                      <div>
                        <input type="checkbox" class="input_replaced input" value="1" id="OPT_IN" name="OPT_IN" required />
                        <span class="checkbox checkbox_tick_positive"></span>
                        <p class="opt-in-text" style="color: rgba(255,255,255,0.8); font-size: 0.875rem;">
                          J'accepte de recevoir vos e-mails et confirme avoir pris connaissance de votre
                          <a href="/legal/privacy.html" style="color: var(--hair-blue);">politique de confidentialité</a>
                          et <a href="/legal/mention.html" style="color: var(--hair-blue);">mentions légales</a>.
                        </p>
                      </div>
                    </label>
                  </div>
                </div>
                <label class="entry__error entry__error--primary"></label>
                <label class="spec-text" style="color: rgba(255,255,255,0.5); font-size: 0.8rem;">
                  Vous pouvez vous désinscrire à tout moment en cliquant sur le lien présent dans nos emails.
                </label>
              </div>
            </div>
          </div>

          <div style="padding: 8px 0">
            <div class="sib-form-block">
              <button form="sib-form" type="submit">
                <svg class="icon clickable__icon progress-indicator__icon sib-hide-loader-icon" viewBox="0 0 512 512" style="width:1em;height:1em;margin-right:0.5rem;">
                  <path d="M460.116 373.846l-20.823-12.022c-5.541-3.199-7.54-10.159-4.663-15.874 30.137-59.886 28.343-131.652-5.386-189.946-33.641-58.394-94.896-95.833-161.827-99.676C261.028 55.961 256 50.751 256 44.352V20.309c0-6.904 5.808-12.337 12.703-11.982 83.556 4.306 160.163 50.864 202.11 123.677 42.063 72.696 44.079 162.316 6.031 236.832-3.14 6.148-10.75 8.461-16.728 5.01z"/>
                </svg>
                S'INSCRIRE
              </button>
            </div>
          </div>

          <input type="text" name="email_address_check" value="" class="input--hidden input" />
          <input type="hidden" name="locale" value="fr" />
        </form>
      </div>
    </div>
  </section>

  <!-- Scripts Brevo — placés en fin de body -->
  <script is:inline>
    window.REQUIRED_CODE_ERROR_MESSAGE = "Veuillez choisir un code pays";
    window.LOCALE = "fr";
    window.EMAIL_INVALID_MESSAGE = window.SMS_INVALID_MESSAGE =
      "Il semble que les informations que vous avez fournies ne soient pas valides. Veuillez vérifier vos données et réessayer.";
    window.REQUIRED_ERROR_MESSAGE = "Ce champ est obligatoire, veuillez le renseigner.";
    window.GENERIC_INVALID_MESSAGE =
      "Il semble que les informations que vous avez fournies ne soient pas valides. Veuillez vérifier vos données et réessayer.";
    window.translation = {
      common: {
        selectedList: "{quantity} liste sélectionnée",
        selectedLists: "{quantity} listes sélectionnées",
        selectedOption: "{quantity} sélectionné",
        selectedOptions: "{quantity} sélectionnés",
      },
    };
    var AUTOHIDE = Boolean(1);
  </script>
  <script src="https://sibforms.com/forms/end-form/build/main.js" is:inline></script>
<script src="https://www.google.com/recaptcha/api.js?render=6LfDOhQsAAAAAP1op3mXkpeQaln-uQ0ucAESOmXG&hl=fr" async defer is:inline></script>
<style>
	.section--tinted {
		background: linear-gradient(to bottom, var(--biumiz-bg-start), var(--biumiz-bg-end)) !important;
		color: var(--white) !important;
	}
</style>
</BiumizLayout>
