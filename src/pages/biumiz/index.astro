	position: relative;
    width: 100%;
    max-width: 180rem;
  }

  .hero-image-wrapper img {
    width: 100%;
    height: auto;
	border-radius: 1.25rem;
    display: block;
  }
  
  .section-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

