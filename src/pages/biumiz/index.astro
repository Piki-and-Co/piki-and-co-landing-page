---
import BiumizLayout from '@/layouts/BiumizLayout.astro';

import { Image } from 'astro:assets';
import imgLandingPage from '@assets/LandingPage.webp';
import conectus from '@assets/CONECTUS-BaselineFR_HD2018_Blanc.webp';
import cnrs from '@assets/LOGO_CNRS_HD.webp';
import unistra from '@assets/Unistra2_HD_FondBlanc.webp';
import logoBiumizFull from '@assets/Logo_Biumiz-Full.webp';

import photoAmandine from '@assets/PhotoAmandine.webp';
import photoKevin from '@assets/PhotoKevin.webp';
import photoLaurence from '@assets/PhotoLaurence.webp';
import photoIris from '@assets/LogoGramophone.webp';
import photoElodie from '@assets/PhotoElodie.webp';
import photoCharlotte from '@assets/PhotoCharlotte.webp';
import photoWren from '@assets/LogoWren.webp';
import photoKubra from '@assets/PhotoKubra.webp';


const team = [
	{
		prenom: "Amandine",
		nom: "Piguel",
		poste: "Co-inventrice de Biumiz, directrice produit",
		description: "A partir des retours des utilisateurs et experts, définit les évolutions à apporter à Biumiz",
		photo: photoAmandine
	},

	{
		prenom: "Laurence",
		nom: "Schmoll",
		poste: "Chercheuse & co-inventrice de Biumiz",
		description: "Spécialiste en didactique des langues et conception de jeux sérieux, elle est l'autrice de la progression en didactique des langues et de l'ingénierie pédagogique",
		photo: photoLaurence
	},
	{
		prenom: "Kevin",
		nom: "Blenner",
		poste: "Développeur coeur",
		description: "Ingénieur en développement logiciel expérimenté, il développe le code informatique du jeu vidéo",
		photo: photoKevin
	},
	{
		prenom: "Iris",
		nom: "Caulliez",
		poste: "Game & Narrative Designer",
		description: "Autrice de la narration et conceptrice des mécaniques de jeu",
		photo: photoIris
	},
	{
		prenom: "Elodie",
		nom: "Magnier",
		poste: "Orthopédagogue & Neuropédagogue",
		description: "Autrice de la progression en didactique des CPS, responsable de l'adéquation du jeu aux besoins des enfants",
		photo: photoElodie
	},
	{
		prenom: "Charlotte",
		nom: "Gahmia",
		poste: "Graphiste/Illustratrice",
		description: "Créatrice de l'univers visuel de Biumiz et des personnages",
		photo: photoCharlotte
	},
	{
		prenom: "Wren",
		nom: "Davies",
		poste: "Graphiste/Illustratrice",
		description: "Au côté de Charlotte dessine les décors et les personnages du jeu",
		photo: photoWren
	},
	{
		prenom: "Kubra",
		nom: "Dag",
		poste: "Ingénieure pédagogique",
		description: "Au côté de Laurence, conçoit l'accompagnement pédagogique de l'adulte et, avec Iris, les jeux de société",
		photo: photoKubra
	}
];


const IndexFaqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
  {
	"@type": "Question",
	"name": "A partir de quel âge mon enfant peut jouer ?",
	"acceptedAnswer": {
	"@type": "Answer",
	"text": "Conformément aux recommandations officielles, Biumiz est conçu pour les enfants à partir de 4 ans. Il est découpé en plusieurs niveaux, chacun calibré par tranche d'âge. Une session du jeu vidéo Biumiz dure 15 minutes maximum. Nous recommandons 1 à 2 sessions par semaine.",
      }
	},
	{
	"@type": "Question",
	"name": "Les jeux vidéo ne sont-ils pas nocifs pour les enfants ?",
	"acceptedAnswer": {
	"@type": "Answer",
	"text": "Ce qui rend les écrans nocifs, c'est l'appauvrissement des interactions sociales. Nos jeux sont conçus pour être un prétexte à l'échange en famille ou en classe. Le jeu vidéo immerge l'enfant dans les notions, puis le jeu de société rassemble tout le monde pour pratiquer ensemble.",
      }
	},
	{
	"@type": "Question",
	"name": "Les enseignants peuvent-ils utiliser Biumiz en classe ?",
	"acceptedAnswer": {
	"@type": "Answer",
	"text": "Absolument ! Nos jeux sont alignés avec les programmes de l'Education Nationale, avec le Cadre Européen Commun de Référence pour les Langues et les recommandations de Santé Publique France sur les CPS. Les différents supports papiers et numériques offrent une flexibilité pédagogique complète.",
      }

	}
   ],
});
---

<BiumizLayout
		title="Biumiz, le jeu qui fait grandir par les langues"
		description="Accompagnez votre enfant dans le développement de ses compétences cognitives, émotionnelles et relationnelles."
		breadcrumbs={[{ name: 'Biumiz', href: '/biumiz' }]}
		faqSchema = {IndexFaqSchema}
		>


<Fragment slot="head">
    <script type="application/ld+json" set:html={IndexFaqSchema}/>
  </Fragment>

	<!-- Hero -->
	<section class="section section--tinted hero-section">
		<div class="hero-container">
			<div class="hero-content">
				<div class="logo-wrapper">
					<Image src={logoBiumizFull} alt="Biumiz" width={1014} height={661} loading="eager" format="webp"/>
				</div>
				<p class="section-eyebrow">Pour les enfants de 4 à 10 ans</p>
				<h1 class="hero-title">Biumiz, le jeu qui construit 
					<span class="highlight">l'équilibre mental</span> de votre enfant</h1>
				<p class="hero-description">
					Faites vivre de grandes histoires à votre enfant avec Biumiz ! 
					Plongé dans un univers ludique, positif, engageant et profondément respectueux de ses besoins,
					votre enfant développe ses compétences humaines en apprenant à communiquer en anglais,
					tout en s'amusant en famille ou en classe !
				</p>
				<div class="hero-ctas">
					<a href="/inscription" class="btn btn-primary">S'inscrire !</a>
				</div>
			</div>
				<div class="hero-image-container">
					<div class="hero-image-wrapper">
						<Image src={imgLandingPage} alt="Rejoingez Biumiz dans ses aventures !" 
						width={8268} height={5374} loading="eager" format="webp"/>
				</div>
			</div>
		</div>
	</section>	
	
	<!-- Conçu pour vous -->
	<section class="section " id="PourVous">
		<div class="container">
			<p class="section-eyebrow">Conçu pour vous et avec vous</p>
			<h2 class="section-heading">Un produit ancré dans votre quotidien</h2>
			<p class="section-lead">
				Depuis ses tous débuts, Biumiz est co-construit avec des parents et des professionnel·le·s des enfants
				pour être au plus proche de vos besoins et de votre réalité. 				
			</p>
			<div class="grid">
				<div class="card">
					<span class="icon">👨‍👩‍👧‍👦</span>
					<h3>Parents</h3>
					<p>Offrez à votre enfant les compétences nécessaire à son épanouissement 
						et son bien-être mental et émotionnel tout au long de sa vie. 
					</p>
					<ul class="custom-features-list">
						<li>Jeux conçus avec des chercheur·se·s universitaires</li>
						<li>Usage du numérique sain et encadré : environ 15 minutes une à deux fois par semaine</li>
						<li>Moments de partage en famille avec le jeu de société</li>
						<li>Apprentissage des langues étrangères par l'immersion orale</li>
						<li>Adapté à chaque tranche d'âge</li>
					</ul>
				</div>
				<div class="card">
					<span class="icon">🎓</span>
					<h3>Enseignant·e·s de primaire</h3>
					<p>Un outil clef en main pour développer les compétences psychosociales de vos élèves et 
					enseigner l'anglais.</p>
					<ul class="custom-features-list">
						<li>Aligné avec les programmes de l'Education Nationale, les recommandations de Santé Publique France
						et le CECRL.</li>
						<li>Développe les trois familles de compétences psychosociales</li>
						<li>Apprentissage des langues étrangères par une approche communicative et actionnelle</li>
					</ul>

				</div>
			</div>

		</div>
	</section>

	<!-- Partenaires -->
	<section class="section section--tinted" id="partenaires">
		<div class="container">
			<p class="section-eyebrow">Nous travaillons ensemble</p>
			<h2 class="section-heading">Nos partenaires</h2>
			<div class="partners-grid">
				<div class="partner-card">
					<Image src={conectus} alt="SATT Conectus d'Alsace" 
					width={6184} height={2009} loading="eager" format="webp"/>
				</div>
				<div class="partner-card">
					<Image src={cnrs} alt="Centre Nationale de la Recherche Scientifique" 
					width={705} height={705} loading="eager" format="webp"/>
				</div>
				<div class="partner-card">
					<Image src={unistra} alt="Université de Strasbourg" 
					width={3310} height={1193} loading="eager" format="webp"/>
				</div>
			</div>
		</div>
	</section>	

  <!-- FAQ -->
  <section class="section faq" id="faq">
    <div class="container">
      <p class="section-eyebrow">Question fréquentes</p>
      <details class="faq-parent">
        <summary>A partir de quel âge mon enfant peut jouer ?</summary>
		<p>Conformément aux recommandations officielles, Biumiz est conçu pour les enfants à partir de 4 ans. Il est découpé en plusieurs niveaux, chacun calibré par tranche d'âge. Une session du jeu vidéo Biumiz dure 15 minutes maximum, à raison d'une à deux sessions par semaine.</p>
      </details>
      <details class="faq-parent">
        <summary>Les jeux vidéo ne sont-ils pas nocifs pour les enfants ?</summary>
		<p>Ce qui rend les écrans nocifs, c'est l'appauvrissement des interactions sociales. Nos jeux sont conçus pour être un prétexte à l'échange en famille ou en classe. Le jeu vidéo immerge l'enfant dans les notions, puis le jeu de société rassemble tout le monde pour pratiquer ensemble.</p>
      </details>
      <details class="faq-parent">
        <summary>Les enseignants peuvent-ils utiliser Biumiz en classe ?</summary>
		<p>Absolument ! Nos jeux sont alignés avec les programmes de l'Education Nationale, avec le Cadre Européen Commun de Référence pour les Langues et les recommandations de Santé Publique France sur les CPS. Les différents supports papiers et numériques offrent une flexibilité pédagogique complète.</p>
      </details>
    </div>
  </section>

	<section class="section section--tinted" id="Equipe">
		<div class="container" style="text-align: center;">
			<p class="section-eyebrow">Les créateurs.trices de Biumiz</p>
			<h2 class="section-heading-pikico">L'équipe</h2>
			<div class="team-list">
				{team.map((member) => (
					<div class="team-card">
						<div class="team-photo-wrapper">
							<div class="photo-disk">
								<Image src={member.photo} alt={`${member.prenom} ${member.nom}`}
								width={300} height={300} format="webp"/>
							</div>
						</div>

							<div class="team-info">
								<h3 class="team-name">{member.prenom} <span>{member.nom}</span></h3>
								<p class="team-role">{member.poste}</p>
								<p class="team-description">{member.description}</p>
							</div>
						</div>
					))}
			</div>
		</div>
	</section>

	<section class="cta-section">
		<h2>Prêt à entrer dans l'aventure<br />qui fait grandir ?</h2>
		<a href="/inscription" class="btn-primary">Rejoignez l'aventure !</a>
	</section>

</BiumizLayout>

<style>
	/* Base de la section avec le violet foncé d'origine */
	.hero-section {
		padding: 4rem 4rem;
		overflow: hidden;
	}

	/* Layout en grille : 2 colonnes sur PC, 1 seule colonne empilée sur mobile */
	.hero-container {
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: center;
		width: 100%;
		max-width: 24rem;
	}

	@media (min-width: 48rem) {
		.hero-container {
			grid-template-columns: 0.9fr 1.1fr; /* La colonne de texte est légèrement plus large */
			max-width: 90rem;
		}
	}

	.hero-ctas .btn-primary { 
		margin-top: 1.5rem;
		margin-bottom: 1.5rem;
	}

	/* Éléments de gauche */
	.logo-wrapper {
		width: 14rem;
		height: auto;
		margin-bottom: 2.5rem;
	}
	.logo-wrapper img {
		width: 100%;
		height: auto;
		display: block; /* Évite un petit espace vide sous l'image */
	}

	.hero-title {
		font-size: 2.5rem;
		font-weight: 800; /* Très gras */
		line-height: 1.15;
		margin-bottom: 1.5rem;
		letter-spacing: -0.02em;
	}

	@media (min-width: 64rem) {
		.hero-title {
		font-size: 3.5rem; /* Titre très grand sur grand écran */
		}
	}

	.hero-description {
		font-size: 1.125rem;
		font-weight: 400; /* Épaisseur normale/fine */
		line-height: 1.6;
		max-width: 540px;
	}

	/* Éléments de droite (Image et Badge) */
	.hero-image-container {
		display: flex;
		justify-content: center;
	}

	.hero-image-wrapper {
		position: relative;
		width: 100%;
		max-width: 180rem;
	}

	.hero-image-wrapper img {
		width: 100%;
		height: auto;
		border-radius: 1.25rem;
		display: block;
	}
	.section { 
		padding: var(--section-gap) 0; 
		background: var(--light-purple);
	}

	.section--tinted {
		background: linear-gradient(to bottom, var(--biumiz-bg-start), var(--biumiz-bg-end)) !important;
		color: var(--white) !important;
	}

	.section-eyebrow {
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 0.75rem;
	}

	.section-heading {
		font-family: var(--font-display);
		font-size: clamp(1.8rem, 4vw, 2.5rem);
		font-weight: 400;
		margin-bottom: 2rem;
	}

	.section-lead {
		text-align: center;
		max-width: 44rem;
		margin: 0 auto 3rem;
		font-size: 1.05rem;
		line-height: 1.8;
		opacity: 0.9;
	}
	
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
		gap: 1.5rem;
		margin-bottom: 3rem;
	}

	.card {
		background: white;
		border: 2px solid var(--light-purple);
		border-radius: 0.75rem;
		padding: 2rem;
		text-align: center;
		box-shadow: 0 10px 30px -10px rgba(18, 19, 44, 0.3);
		color: var(--dark-purple); /* Assure la lisibilité du texte dans la carte */
	}

	.icon { 
		font-size: 2.5rem; 
		display: block; 
		margin-bottom: 1rem; 
	}

	.card h3 { 
		margin-bottom: 0.5rem;
		font-size: 1.1rem;
		color: var(--dark-purple);
	}

	.card p { 
		font-size: 0.9rem; 
	}

	.partners-grid { 
		display: grid; 
		grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr)); 
		gap: 2rem; 
		align-items: center; 
		justify-items: center;
		margin-top: 3rem;
	}
	.partner-card img { 
		max-width: 10rem; 
		height: auto; 
		opacity: 0.85; 
		transition: opacity 0.3s; 
	}
	.partner-card img:hover { 
		opacity: 1; 
	}

	.custom-features-list {
		list-style: none; /* 1. Supprime les gros ronds noirs par défaut */
		padding-left: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem; /* Espace vertical entre chaque puce */
		margin-top: 1rem;
	}

	.custom-features-list li {
		position: relative;
		padding-left: 2rem; /* Crée de l'espace à gauche pour placer la coche jaune */
		text-align: left;
		font-size: 0.9rem; 
	}

	/* 2. Création et injection de la coche jaune */
	.custom-features-list li::before {
		content: "✓"; /* Vous pouvez aussi utiliser l'icône de votre choix */
		position: absolute;
		left: 0;
		top: 0;
		color: var(--dark-yellow); /* Utilise le jaune de votre charte graphique Biumiz */
		font-weight: 900; /* Rend la coche un peu plus épaisse */
		font-size: 1.2rem;
	}

  .team-list {
    display: grid;
    grid-template-columns: 1fr; /* Une carte par ligne */
    gap: 1.5rem;
    max-width: 55rem;
    margin: 3rem auto 0;
  	}

  @media (min-width: 64rem) {
    .team-list {
        grid-template-columns: 1fr 1fr; /* Deux cartes par ligne sur grand écran */
        max-width: 65rem;
    }
  }

	/* --- LA CARTE D'IDENTITÉ --- */
	.team-card {
		background: var(--light-purple);
		border-radius: 1.5rem;
		padding: 1rem;
		display: flex;
		flex-direction: column; /* Empilé par défaut sur mobile */
		align-items: center;
		gap: 1rem;
		text-align: center;
		transition: transform 0.3s ease;
		box-shadow: 0 10px 25px -5px rgba(18, 19, 44, 0.3);
	}

	@media (min-width: 48rem) {
	.team-card {
			flex-direction: row; /* En colonnes (Photo | Texte) sur PC */
			text-align: left;
			padding: 1.75rem;
		}
	}

	/* --- LE DISQUE PHOTO --- */
	.team-photo-wrapper {
		flex-shrink: 0;
	}

	.photo-disk {
		width: 6rem;
		height: 6rem;
		border-radius: 50%; /* Forme de disque parfait */
		overflow: hidden;
		border: 0.25rem solid var(--white);
		box-shadow: 0 4px 15px rgba(0,0,0,0.1);
	}

	@media (min-width: 48rem) {
	.photo-disk {
			width: 7.5rem;
			height: 7.5rem;
		}
	}

	.photo-disk img {
		width: 100%;
		height: 100%;
		object-fit: cover; /* L'image remplit le disque sans déformation */
	}

	/* --- LES TEXTES --- */
	.team-info {
		display: flex;
		flex-direction: column;
		gap: 0rem;
	}

	.team-name {
		font-family: var(--font-display);
		font-size: 1.5rem;
		color: var(--dark-purple);
		margin: 0;
		line-height: 1;
	}

	.team-name span {
		color: var(--pikico-accent); /* Met en valeur le nom de famille */
	}

	.team-role {
		font-size: 1rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--hair-blue);
		margin-bottom: 0.2rem;
	}

	.team-description {
		font-size: 1rem;
		line-height: 1.5;
		color: var(--dark-purple);
		opacity: 0.9;
		margin: 0;
	}

	.faq { 
		padding: 3rem 0; 
	}

	.section-title {
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1rem;
		color: var(--hair-blue);
		margin-bottom: 0.75rem;
	}

	/* Le parent Accordéon */
	details.faq-parent { 
		margin-bottom: 1rem; 
		overflow: hidden; 
		border-radius: 0.5rem;
		text-align: left;
	}

	summary { 
		padding: 1rem 1.5rem; 
		cursor: pointer; 
		font-weight: bold; 
		transition: background-color 0.3s; 
		list-style: none;
	}
	summary::-webkit-details-marker { display: none; } /* Enleve la flèche native */
	summary::after { content: "+"; float: right; }
	details[open] > summary::after { content: "−"; }

	details.faq-parent p, 
	details.faq-parent ul, 
	details.faq-parent h3 { 
		padding: 0.5rem 1.5rem; 
	}

	details.faq-parent ul {
		margin-left: 3rem;
		margin-bottom: 1rem;
	}

	.quoting { 
		font-size: 0.8rem; 
		opacity: 0.7;
		font-style: italic;
	}

	.faq-child { 
		margin-left: 1.5rem; 
		margin-top: 0.5rem; 
		border-radius: 0.25rem;
	}
	.faq-child > summary { font-size: 0.95rem; font-weight: 600; }
</style>
