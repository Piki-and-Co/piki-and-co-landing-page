---
import PikiCoLayout from '@/layouts/PikiCoLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.png';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<PikiCoLayout
  title="Accueil"
  description="Jouer, s'éveiller, s'accomplir. Accompagnez votre enfant dans le développement des compétences psychosociales grâce à une utilisation saine du numérique."
>
  <!-- Hero -->
  <section class="section hero-section">
    <div class="container hero-grid">
      <div class="hero-content">
        <p class="hero-eyebrow">Pour les enfants de 4 à 10 ans</p>
        <h1>Jouer, s'éveiller,<br />s'accomplir.</h1>
        <p class="hero-lead">
		En collaboration avec la recherche académique française, Piki&nbsp;&amp;&nbsp;Co développe des jeux
		narratifs, immersifs et multi-supports pour vous accompagner dans le développement des compétences 
		psychosociales de votre enfant, socle de sa santé mentale et émotionnelle tout au long de sa vie.
        </p>
        <div class="hero-ctas">
          <a href="/biumiz" class="btn btn-primary">Découvrir Biumiz</a>
          <a href="#mission" class="btn btn-outline">Notre mission</a>
        </div>
      </div>
      <div class="hero-visual">
		<Image src={logoImage} alt="Piki & Co" width={309} height={220} loading="eager" format="webp"/>
      </div>
    </div>
  </section>

  <!-- Mission / CPS -->
  <section class="section section--tinted" id="mission">
    <div class="container">
      <p class="section-eyebrow">Notre mission</p>
      <h2 class="section-heading-pikico">Les compétences psychosociales (CPS), c'est quoi ?</h2>
      <p class="section-lead">
        Définies par l'OMS, les compétences psychosociales sont les capacités qui permettent
        à un individu de faire face aux exigences et aux défis de la vie quotidienne.
        Elles sont <strong>indispensables à la santé mentale positive</strong> et au bien-être
        dès le plus jeune âge.
      </p>
      <div class="cps-grid">
        <div class="cps-card">
          <span class="cps-icon">🤝</span>
          <h3>Compétences sociales</h3>
          <p>Empathie, communication efficace, coopération, résolution de conflits.</p>
        </div>
        <div class="cps-card">
          <span class="cps-icon">🧠</span>
          <h3>Compétences cognitives</h3>
          <p>Esprit critique, créativité, prise de décision, résolution de problèmes.</p>
        </div>
        <div class="cps-card">
          <span class="cps-icon">💛</span>
          <h3>Compétences émotionnelles</h3>
          <p>Conscience de soi, gestion des émotions, gestion du stress et de l'anxiété.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Notre approche / valeurs -->
  <section class="section" id="approche">
    <div class="container">
      <p class="section-eyebrow">Notre approche</p>
      <h2 class="section-heading-pikico">Le numérique au service de l'enfant</h2>
      <div class="values-grid">
        <div class="value-item">
          <div class="value-number">01</div>
          <h3>Fondé sur la science</h3>
          <p>
            Nos outils s'appuient sur les recherches en psychologie positive, neurosciences
            et pédagogie active pour garantir un impact réel sur le développement de l'enfant.
          </p>
        </div>
        <div class="value-item">
          <div class="value-number">02</div>
          <h3>Le jeu comme vecteur</h3>
          <p>
            Le jeu vidéo immersif est notre medium principal — engageant, motivant, et parfaitement
            adapté aux enfants d'aujourd'hui pour apprendre sans s'en rendre compte.
          </p>
        </div>
        <div class="value-item">
          <div class="value-number">03</div>
          <h3>Conçu avec les familles</h3>
          <p>
            Parents, enseignants et professionnels de santé contribuent à la co-construction
            de nos outils pour qu'ils répondent aux vrais besoins du terrain.
          </p>
        </div>
        <div class="value-item">
          <div class="value-number">04</div>
          <h3>Bilinguisme intégré</h3>
          <p>
            Chaque expérience Biumiz intègre naturellement deux langues pour développer
            les capacités cognitives liées au bilinguisme dès 4 ans.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Produit phare -->
  <section class="section section--tinted" id="biumiz">
    <div class="container product-spotlight">
      <div class="product-text">
        <p class="section-eyebrow">Notre premier outil</p>
        <h2 class="section-heading-pikico" style="text-align: left;">Biumiz — L'app qui fait grandir par le jeu</h2>
        <p>
          Une application mobile et web qui accompagne les enfants de 4 à 10 ans à travers
          des aventures immersives pensées pour développer les CPS — tout en s'amusant,
          en français et en anglais.
        </p>
        <ul class="product-features">
          <li>Jeux vidéo éducatifs et scénarios interactifs</li>
          <li>Progression adaptée à l'âge et au rythme de l'enfant</li>
          <li>Tableau de bord parents pour suivre les progrès</li>
          <li>Gratuit, sans publicité, sans achat intégré</li>
        </ul>
        <a href="/biumiz" class="btn btn-primary" style="margin-top: 1.5rem;">En savoir plus sur Biumiz</a>
      </div>
      <div class="product-image">
        <img
          src="/assets/logo.png"
          alt="Application Biumiz"
          width="300"
          height="300"
          loading="lazy"
          style="opacity: 0.85;"
        />
      </div>
    </div>
  </section>

  <!-- Blog preview -->
  {posts.length > 0 && (
    <section class="section" id="blog">
      <div class="container">
        <p class="section-eyebrow">Le blog</p>
        <h2 class="section-heading-pikico">Nos derniers articles</h2>
        <div class="blog-grid">
          {posts.map(post => (
            <article class="blog-card">
              <div class="blog-card-body">
                <div style="margin-bottom: 0.75rem;">
                  {post.data.tags?.map(tag => (
                    <a href={`/blog/tags/${tag}`} class="blog-card-tag" style="margin-right: 0.5rem;">
                      #{tag}
                    </a>
                  ))}
                </div>
                <h3>
                  <a href={`/blog/${post.slug}`} class="blog-card-link">{post.data.title}</a>
                </h3>
                {post.data.description && (
                  <p>{post.data.description}</p>
                )}
                <p class="blog-card-meta">
                  {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
                  {post.data.author && <> · {post.data.author}</>}
                </p>
              </div>
            </article>
          ))}
        </div>
        <div style="text-align: center; margin-top: 2.5rem;">
          <a href="/blog" class="btn btn-outline">Tous les articles</a>
        </div>
      </div>
    </section>
  )}

  <!-- Partenaires -->
  <section class="section section--tinted" id="partenaires">
    <div class="container" style="text-align: center;">
      <p class="section-eyebrow">Ils nous font confiance</p>
      <h2 class="section-heading-pikico">Nos partenaires</h2>
      <p style="color: var(--pikico-muted); max-width: 38rem; margin: 0 auto;">
        Nous collaborons avec des établissements scolaires,
        des professionnels de santé et des structures petite enfance.
      </p>
    </div>
  </section>

  <!-- CTA final -->
  <section class="section cta-final">
    <div class="container" style="text-align: center;">
      <h2>Prêt à accompagner votre enfant ?</h2>
      <p style="color: var(--pikico-muted); max-width: 36rem; margin: 1rem auto 2rem;">
        Rejoignez les familles qui font confiance à Piki&nbsp;&amp;&nbsp;Co pour accompagner
        leurs enfants dans un apprentissage ludique et bienveillant.
      </p>
      <a href="/inscription" class="btn btn-primary">Rejoindre l'aventure</a>
    </div>
  </section>
</PikiCoLayout>

<style>
  /* Hero */
  .hero-section { padding-top: 4rem; padding-bottom: 4rem; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pikico-accent);
    margin-bottom: 1rem;
  }
  .hero-lead {
    font-size: 1.15rem;
    color: var(--pikico-muted);
    max-width: 38rem;
    margin: 1.25rem 0 2rem;
    line-height: 1.8;
  }
  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero-logo {
    width: 13rem;
    height: auto;
    opacity: 0.9;
  }

  /* Sections */
  .section-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pikico-accent);
    margin-bottom: 0.75rem;
    text-align: center;
  }
  .section-heading-pikico {
    text-align: center;
    margin-bottom: 1.25rem;
  }
  .section-lead {
    text-align: center;
    max-width: 44rem;
    margin: 0 auto 3rem;
    color: var(--pikico-muted);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  /* CPS cards */
  .cps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1.5rem;
  }
  .cps-card {
    background: white;
    border: 1px solid var(--pikico-border);
    border-radius: 0.75rem;
    padding: 2rem;
    text-align: center;
  }
  .cps-icon { font-size: 2.5rem; display: block; margin-bottom: 1rem; }
  .cps-card h3 { margin-bottom: 0.5rem; font-size: 1.1rem; }
  .cps-card p { font-size: 0.9rem; color: var(--pikico-muted); }

  /* Values */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }
  .value-item { padding: 1.5rem 0; border-top: 2px solid var(--pikico-border); }
  .value-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--pikico-border);
    margin-bottom: 0.5rem;
    line-height: 1;
  }
  .value-item h3 { margin-bottom: 0.5rem; }
  .value-item p { color: var(--pikico-muted); font-size: 0.95rem; line-height: 1.7; }

  /* Product spotlight */
  .product-spotlight {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
  }
  .product-features {
    margin: 1.25rem 0 0 1.25rem;
    color: var(--pikico-muted);
    font-size: 0.95rem;
    line-height: 2;
  }
  .product-image img {
    width: 14rem;
    height: auto;
    border-radius: 1rem;
  }

  /* CTA final */
  .cta-final { background: var(--pikico-title); }
  .cta-final h2 { color: white; }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .product-spotlight { grid-template-columns: 1fr; }
    .product-image { display: none; }
  }
</style>
